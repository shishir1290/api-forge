{
  "name": "apiforge",
  "version": "1.0.0",
  "description": "APIForge - A Postman-like desktop API client",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --port 6600",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "cross-env BUILD_TARGET=electron next build && electron-builder",
    "electron:build:win": "cross-env BUILD_TARGET=electron next build && electron-builder --win",
    "electron:build:mac": "cross-env BUILD_TARGET=electron next build && electron-builder --mac",
    "electron:build:linux": "cross-env BUILD_TARGET=electron next build && electron-builder --linux"
  },
  "build": {
    "appId": "com.apiforge.app",
    "productName": "APIForge",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/client": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.9.0",
    "socket.io-client": "^4.8.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
